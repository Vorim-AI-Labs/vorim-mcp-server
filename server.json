{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Vorim-AI-Labs/vorim-mcp-server",
  "description": "AI agent identity, permissions, trust scores, and tamper-evident audit trails via Vorim AI",
  "repository": {
    "url": "https://github.com/Vorim-AI-Labs/vorim-mcp-server",
    "source": "github"
  },
  "version": "1.1.9",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@vorim/mcp-server",
      "version": "1.1.9",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Vorim API key (agid_sk_live_...)",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "VORIM_API_KEY"
        },
        {
          "description": "Vorim API base URL",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "VORIM_BASE_URL"
        }
      ]
    }
  ]
}
